---
import { getEntry, render } from 'astro:content';
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';
import portrait from '../assets/about/portrait.jpg';

const about = await getEntry('pages', 'about');
const { Content } = await render(about!);
---
<Base title="About" description="About peachless. — a visual designer exploring the space between art and functionality.">
  <section class="section section--light">
    <div class="container about-grid">
      <div class="about-content">
        <Content />
      </div>
      <div class="about-portrait">
        <Image
          src={portrait}
          alt="Portrait of Patricia, the designer behind peachless."
          widths={[480, 800, portrait.width]}
          sizes="(max-width: 900px) 92vw, 420px"
        />
      </div>
    </div>
  </section>
</Base>

<style>
  .about-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: clamp(32px, 6vw, 80px);
    align-items: start;
    max-width: 1100px;
  }
  .about-content :global(h3) {
    font-size: clamp(1.3rem, 2.2vw, 1.7rem);
    margin-bottom: 1em;
  }
  .about-content :global(p) {
    max-width: var(--max-ch);
  }
  .about-portrait img {
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow);
  }
  @media (max-width: 900px) {
    .about-grid { grid-template-columns: 1fr; }
    .about-portrait { order: -1; max-width: 420px; }
  }
</style>
