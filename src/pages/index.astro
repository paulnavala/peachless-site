---
import { getEntry } from 'astro:content';
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';
import Tagline from '../components/islands/Tagline.vue';
import TwinGallery from '../components/static/TwinGallery.astro';
import hero from '../assets/home/hero.png';
import '../styles/components/tagline.css';

const home = await getEntry('pages', 'home');
const site = await getEntry('site', 'site');
const { heading, lead, buttonLabel, buttonHref } = home!.data;
---
<Base description={site!.data.defaultDescription} theme="bright">
  <section class="section section--bright home-hero">
    <div class="container">
      <Tagline client:load fixedCenter={true} />
    </div>
  </section>

  <section class="section section--light home-intro">
    <div class="container">
      <!-- Live composition: lockup image first in source (stacks first on mobile),
           text column pulled left of it at desktop via order. -->
      <div class="home-intro__media">
        <Image src={hero} alt="" widths={[480, 1000, hero.width]} sizes="(max-width: 739px) 220px, 480px" />
      </div>
      <div class="home-intro__text">
        <h3>{heading}</h3>
        <p set:html={lead} />
        <a class="btn-primary" href={buttonHref}>{buttonLabel}</a>
      </div>
    </div>
  </section>

  <section class="section section--light">
    <div class="container">
      <TwinGallery />
    </div>
  </section>
</Base>

<style>
  /* Live clay band is ~260px tall at 1440: .section padding + the tagline itself.
     No extra min-height (the old 55vh tripled the band height). */
  .home-hero .container {
    min-height: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  @media (max-width: 480px) {
    /* Live renders the tagline on a single line (~18-19px) at 390px */
    .home-hero :global(.tagline.typewriter) {
      font-size: 1.2rem;
    }
  }

  /* Intro: stacked (image → heading → lead → CTA) on mobile,
     two columns (text left / lockup right) from 740px — matches live. */
  .home-intro .container {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
    text-align: left;
  }
  .home-intro__media {
    display: flex;
    justify-content: center;
    align-items: center;
  }
  .home-intro__media img {
    width: 100%;
    max-width: 220px;
    height: auto;
  }
  .home-intro__text {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 16px;
  }
  .home-intro h3 {
    /* Live: ~30px at 390, ~35px at 1440 */
    font-size: clamp(1.8rem, 1.2rem + 1.6vw, 2.2rem);
    margin: 0;
  }
  .home-intro p {
    margin: 0;
  }
  @media (min-width: 740px) {
    .home-intro .container {
      grid-template-columns: 1.15fr 1fr;
      align-items: center;
      gap: clamp(32px, 5vw, 80px);
    }
    .home-intro__text {
      order: -1; /* text column left, lockup right (live composition) */
    }
    .home-intro__media img {
      /* Live lockup: ~230px at 768, ~450-500px at 1440 */
      max-width: clamp(240px, 32vw, 480px);
    }
  }
  .btn-primary {
    display: block;
    width: min(490px, 100%);
    box-sizing: border-box;
    background: var(--clay);
    color: #fff;
    text-decoration: none;
    text-align: center;
    padding: 14px 24px;
    border-radius: var(--radius-xl);
    font-size: 0.95rem;
    transition: background 0.3s ease;
  }
  .btn-primary:hover {
    background: var(--clay-dark);
  }
</style>
