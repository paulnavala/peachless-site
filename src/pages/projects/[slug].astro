---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((p) => ({ params: { slug: p.id }, props: { project: p } }));
}

const { project } = Astro.props;
const { title, description, badges, year, figma } = project.data;
const embed = `https://www.figma.com/embed?embed_host=share&url=${encodeURIComponent(figma)}`;
---
<Base title={title} description={description}>
  <article class="case-study section section--light">
    <div class="container">
      <a class="case-back" href="/projects/uiux">← Back to UI/UX</a>
      <h1>{title}</h1>
      <p class="case-meta">
        {badges.map((b) => <span class="badge">{b}</span>)}
        {year && <span class="case-year">{year}</span>}
      </p>
      <p class="case-description">{description}</p>
      <div class="case-frame">
        <iframe src={embed} title={`${title} prototype`} loading="lazy" allowfullscreen></iframe>
      </div>
    </div>
  </article>
</Base>

<style>
  .case-study .container { max-width: 1100px; }
  .case-back {
    display: inline-block;
    margin-bottom: 24px;
    color: var(--text-muted);
    text-decoration: none;
  }
  .case-back:hover { color: var(--ink-strong); }
  .case-meta {
    display: flex;
    gap: 10px;
    align-items: center;
    flex-wrap: wrap;
  }
  .badge {
    background: var(--card-bg);
    color: var(--cacao);
    border: 1px solid rgba(var(--shadow-color), 0.15);
    border-radius: 999px;
    padding: 4px 14px;
    font-size: var(--step--1);
  }
  .case-year { color: var(--text-light); font-size: var(--step--1); }
  .case-description { max-width: var(--max-ch); font-size: var(--step-1); }
  .case-frame {
    margin-top: 32px;
    border-radius: var(--radius-xl);
    overflow: hidden;
    box-shadow: var(--shadow);
    background: var(--card-bg);
    aspect-ratio: 16 / 10;
  }
  .case-frame iframe { width: 100%; height: 100%; border: 0; }
</style>
