---
import Base from '../../layouts/Base.astro';
import ProjectCards from '../../components/islands/ProjectCards.vue';
// Live cascade order: core (visual) first, layout second — so the layout file's
// 20px gaps and min-width:720px two-column rule win, as they did on live.
import '../../styles/components/project-cards-core.css';
import '../../styles/components/project-cards.css';

const items = [
  {
    href: '/projects/logo-design',
    title: 'Logo Design',
    description: 'Identity work — logos crafted with intention.',
    className: 'graphic-design',
  },
  {
    href: '/projects/uiux',
    title: 'UI/UX',
    description: 'Interfaces and prototypes that connect with people.',
    className: 'ui-ux',
  },
];
const guideline = {
  href: '/projects/guidelines',
  title: 'Guidelines',
  description: 'Brand standards and visual identity.',
};
---
<Base title="Projects" description="Selected projects — logo design, UI/UX, and brand guidelines by peachless.">
  <h1 class="sr-only">Projects</h1>
  <section class="section section--light projects-section">
    <div class="container">
      <ProjectCards client:visible items={items} guideline={guideline} />
    </div>
  </section>
</Base>

<style is:global>
  /* Live sat the component in a full-bleed Squarespace section: the component's own
     gutter (40px desktop / 20px mobile) is the only inset, and the card row renders
     1100px wide at 1440 (core's max-width:1100px was content-box on live). */
  section.projects-section {
    padding-inline: 0;
  }
  .container .project-cards-container {
    max-width: 1180px;
  }
  /* Below 900px live is truly full-bleed: only the component's own 20px mobile
     gutter applies (the .container 92vw cap was adding ~16-31px extra inset). */
  @media (max-width: 900px) {
    .projects-section .container {
      max-width: none;
    }
  }
  /* Live's Squarespace global `h1,h2,h3,h4 { margin: 2rem 0 }` applied INSIDE the
     ported cards (only margin-bottom was overridden by the component CSS, and live
     paragraphs carried their own top spacing). Our global.css resets headings to
     `0 0 .5em`, which compressed the cards ~45px. Restore live's internal rhythm
     page-scoped — the ported component CSS stays byte-identical. */
  .projects-section .project-card h2,
  .projects-section .guideline-button h2 {
    margin: 2rem 0;
  }
</style>
