---
import { Font } from 'astro:assets';
import Seo from '../components/Seo.astro';
import Header from '../components/chrome/Header.astro';
import Footer from '../components/chrome/Footer.astro';
import '../styles/tokens.css';
import '../styles/global.css';

interface Props {
  title?: string;
  description: string;
  theme?: 'light' | 'bright'; // header/first-section theme; home uses 'bright'
}
const { title, description, theme = 'light' } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/icons/icon-32.png" type="image/png" sizes="32x32" />
    <link rel="icon" href="/icons/icon-192.png" type="image/png" sizes="192x192" />
    <link rel="apple-touch-icon" href="/icons/apple-touch-icon.png" />
    <Seo title={title} description={description} />
    <Font cssVariable="--font-marcellus" preload />
    <Font cssVariable="--font-pt-serif" preload />
    <link rel="sitemap" href="/sitemap-index.xml" />
  </head>
  <body>
    <Header theme={theme} />
    <main id="main">
      <slot />
    </main>
    <Footer />
  </body>
</html>
