---
import { Image } from 'astro:assets';
import { getEntry } from 'astro:content';
import logo from '../../assets/logo/peachless-logo.png';
import MobileMenu from './MobileMenu.astro';

interface Props {
  theme?: 'light' | 'bright';
}
const { theme = 'light' } = Astro.props;
const site = await getEntry('site', 'site');
const nav = site!.data.nav;
const current = Astro.url.pathname.replace(/\/$/, '') || '/';
---
<header class={`site-header site-header--${theme}`}>
  <div class="site-header__inner">
    <a class="site-header__title" href="/">peachless.</a>
    <a class="site-header__logo" href="/" aria-label="peachless. — home">
      <Image src={logo} alt="" width={240} densities={[1, 2]} loading="eager" />
    </a>
    <nav class="site-header__nav" aria-label="Primary">
      {nav.map((item) => (
        <a href={item.href} aria-current={current === item.href ? 'page' : undefined}>
          {item.label}
        </a>
      ))}
    </nav>
    <button class="site-header__burger" type="button" aria-label="Open menu" aria-expanded="false">
      <span></span><span></span>
    </button>
  </div>
</header>
<MobileMenu nav={nav} />

<style>
  .site-header {
    position: relative;
    z-index: 10;
  }
  .site-header--light {
    background: var(--linen);
    color: #000;
  }
  .site-header--bright {
    background: var(--clay);
    color: #fff;
  }
  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    position: relative;
    /* Live header is near full-bleed (~57-60px insets at 1440), not container-capped */
    max-width: none;
    margin-inline: auto;
    padding: 24px clamp(16px, 4vw, 60px);
    min-height: var(--header-height);
    box-sizing: border-box;
  }
  .site-header__title {
    font-family: var(--font-heading);
    font-size: 1.35rem;
    text-decoration: none;
    margin-right: auto;
  }
  /* Live renders the wordmark in the clay accent on linen subpages
     (Squarespace siteTitleColor -> accent #d29a84); nav links stay black. */
  .site-header--light .site-header__title {
    color: var(--clay);
  }
  /* Logo PNG absolutely centered — ported intent of old core/header.css (100×40, 120×50 mobile) */
  .site-header__logo {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    width: 100px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .site-header__logo img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }
  .site-header__nav {
    display: flex;
    gap: 28px;
    margin-left: auto;
  }
  .site-header__nav a {
    text-decoration: none;
    font-size: 0.95rem;
  }
  .site-header__nav a:hover,
  .site-header__nav a[aria-current='page'] {
    text-decoration: underline;
    text-underline-offset: 4px;
  }
  .site-header__burger {
    display: none;
    background: none;
    border: 0;
    /* <button> does not inherit color — without this the icon is always UA black */
    color: inherit;
    cursor: pointer;
    padding: 8px;
    flex-direction: column;
    gap: 5px;
  }
  .site-header__burger span {
    display: block;
    width: 22px;
    height: 2px;
    background: currentColor;
  }
  @media (max-width: 900px) {
    .site-header__nav { display: none; }
    .site-header__burger { display: flex; }
    /* Live steps the wordmark down to Squarespace's mobile title size (~16px) */
    .site-header__title { font-size: 1rem; }
  }
  /* Live tablet header is ~129px tall (logo centered at y≈64) on projects /
     logo-design / photography at 768; phones stay ~88px and desktop stays 88px. */
  @media (min-width: 600px) and (max-width: 900px) {
    .site-header__inner { min-height: 128px; }
  }
  @media (max-width: 768px) {
    .site-header__logo { width: 120px; height: 50px; }
  }
</style>
